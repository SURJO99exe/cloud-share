{
  "name": "cloud-share-app",
  "version": "1.0.0",
  "description": "Premium Cloud Share - File Sharing App",
  "main": "electron/main.js",
  "homepage": ".",
  "scripts": {
    "start": "node index.js",
    "electron": "electron .",
    "electron-build": "electron-builder",
    "android:add": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "build:apk": "npx cap sync android && cd android && ./gradlew assembleRelease",
    "cap:init": "npx cap init CloudShare com.cloudshare.app --web-dir public"
  },
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "uuid": "^9.0.0",
    "qrcode": "^1.5.3",
    "os": "^0.1.2",
    "path": "^0.12.7",
    "fs": "^0.0.1-security"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.cloudshare.app",
    "productName": "Cloud Share",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.js",
      "public/**/*",
      "uploads/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  },
  "keywords": [
    "file-sharing",
    "cloud",
    "server",
    "p2p"
  ],
  "author": "Cloud Share Team",
  "license": "MIT"
}
